      "declarations": [
        {
          "kind": "class",
          "description": "Purpose: A custom select dropdown component for selecting one option from a list.\nCategory: Forms\nWhen to use: When you need to present a list of options for the user to choose from.\nWhen not to use: For single input fields or when space is not a concern.\nWorks with components: mc-accordion-item, mc-card, mc-dialog, mc-drawer, mc-modal, mc-popover, mc-step-indicator-item, mc-table, mc-tabs\nAlternative component names: Dropdown, ComboBox, Select Box, Picklist",
          "name": "McSelect",
          "cssParts": [
            {
              "description": "for changing visuals of label container",
              "name": "`label-container`"
            },
            {
              "description": "for changing visuals of label",
              "name": "`label`"
            },
            {
              "description": "for changing visuals of selected option field",
              "name": "`selected-option`"
            },
            {
              "description": "for changing i.e. z-index of popover content",
              "name": "`popover-content`"
            }
          ],
          "slots": [
            {
              "description": "The default slot where the options and dividers go",
              "name": ""
            },
            {
              "description": "The label HTML to use for the mc-input.",
              "name": "`label`"
            },
            {
              "description": "The hint HTML to use for the mc-input.",
              "name": "`hint`"
            },
            {
              "description": "The errormessage HTML to use for the mc-input.",
              "name": "`errormessage`"
