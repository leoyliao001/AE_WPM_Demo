{
  "name": "@maersk-global/shared-js",
  "version": "5.16.2",
  "description": "Maersk shared vanilla JavaScript files",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch --verbose=true",
    "build": "npm run build:cjs && npm run build:es",
    "build:es": "cross-env NODE_ENV=production rollup -c -f es",
    "build:cjs": "cross-env NODE_ENV=production rollup -c -f cjs",
    "build:doc": "typedoc src/index.ts --options typedoc.json",
    "prettify": "pretty-quick --staged",
    "lint": "eslint src/**/*.ts --fix",
    "pre-commit": "npm run prettify && npm run lint && npm run test && npm run build"
  },
  "files": [
    "index.html",
    "assets/",
    "dist/",
    "*.js",
    "**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Maersk-Global/shared-js"
  },
  "homepage": "https://maersk-global.github.io/shared-js",
  "author": "Maersk Front End Community",
  "license": "UNLICENSED",
  "peerDependencies": {
    "core-js": "^3.21.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-typescript": "^7.23.3",
    "@rollup/plugin-commonjs": "^24.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^27.5.2",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^18.19.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^27.5.1",
    "babel-plugin-transform-async-to-promises": "^0.8.18",
    "core-js": "^3.34.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1",
    "jest-environment-jsdom-global": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "rollup": "^2.79.1",
    "rollup-plugin-babel": "^4.4.0",
    "ts-jest": "^27.1.5",
    "tslib": "^2.6.2",
    "typedoc": "^0.24.8",
    "typescript": "^4.9.5",
    "yorkie": "^2.0.0"
  },
  "gitHooks": {
    "pre-commit": "npm run pre-commit"
  }
}
