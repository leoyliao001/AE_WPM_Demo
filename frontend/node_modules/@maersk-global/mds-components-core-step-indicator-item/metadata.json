{
  "overview": {
    "packageName": "@maersk-global/mds-components-core-step-indicator-item",
    "packageVersion": "2.170.3",
    "description": "A component for displaying a step indicator for a process or workflow.",
    "homepage": "https://designsystem.maersk.com",
    "repository": {
      "type": "git",
      "url": "https://github.com/Maersk-Global/mds.git"
    },
    "tagName": "mc-step-indicator-item",
    "customElement": true,
    "category": "Forms, Navigation",
    "purpose": "A component for displaying a step indicator for a process or workflow.",
    "whenToUse": [
      "When you need to visually represent the progress of a multi-step process."
    ],
    "whenNotToUse": [
      "For single-step processes or when a simple progress bar suffices."
    ],
    "worksWithComponents": [
      "mc-step-indicator"
    ],
    "alternativeComponentNames": [
      "Step Progress Indicator",
      "Stepper",
      "Progress Tracker"
    ],
    "extraNotes": "",
    "summary": {
      "publicProperties": 8,
      "publicMethods": 0,
      "events": 0,
      "slots": 2,
      "cssParts": 4,
