  "usage": {
    "import": "import '@maersk-global/mds-components-core-step-indicator-item';",
    "examples": {
      "minimal": "<mc-step-indicator-item></mc-step-indicator-item>",
      "basic": "<mc-step-indicator-item label=\"Label\" state=\"pending\" orientation=\"horizontal\" fit=\"medium\" icon=\"\" appearance=\"default\"></mc-step-indicator-item>",
      "advanced": {
        "IconAsSlot": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-step-indicator-item\";\n\n<mc-step-indicator-item\n  state=\"completed\"\n  label=\"ETD\">\n    <span slot=\"icon\">⏱️</span>\n</mc-step-indicator-item>  ",
        "CustomisedAppearance": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-step-indicator-item\";\n\n// CSS\nmc-step-indicator-item::part(marker) {\n  background-color: #40AB35;\n  border-color: #40AB35;\n}\nmc-step-indicator-item::part(step):after {\n  background-color: #40AB35;\n}\nmc-step-indicator-item::part(icon) {\n  fill: #FFFFFF;\n}\n\n// HTML\n<mc-step-indicator-item\n  state=\"completed\"\n  icon=\"clock\"\n  label=\"ETD\">\n</mc-step-indicator-item>\n  ",
        "CustomLabels": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-step-indicator-item\";\n\n// HTML\n<mc-step-indicator-item\n  state=\"completed\"\n  icon=\"clock\">\n  <span>\n    <span class=\"mds-text--small-normal\">ETD</span>\n    <span class=\"mds-text--x-small-normal\">30-08-2022<br />Rotterdam</span>\n  </span>\n</mc-step-indicator-item>\n  "
      }
    },
