  "api": {
    "props": [
      {
        "name": "singleexpand",
        "type": "boolean",
        "defaultValue": false,
        "description": "If the attribute is is set, then all opened items will be closed when another item is opened.",
        "options": [],
        "required": false,
        "category": "Content"
      },
      {
        "name": "withborder",
        "type": "boolean",
        "defaultValue": false,
        "description": "When true, adds borders all around the accordion container.",
        "options": [],
        "required": false,
        "category": "Style"
      },
      {
        "name": "expandiconposition",
        "type": "ExpandIconPosition",
        "defaultValue": "right",
        "description": "Position of the expand icon",
        "options": [
          "left",
          "right"
        ],
        "required": false,
