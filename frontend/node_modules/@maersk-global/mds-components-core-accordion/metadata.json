        "setup": "npm install @maersk-global/mds-components-core-accordion",
        "import": "import { McAccordion } from \"@maersk-global/mds-react-wrapper/components-core/mc-accordion\";",
        "minimal": "<McAccordion\n  change={yourEventHandler(e)}>\n</McAccordion>",
        "basic": "<McAccordion\n  singleexpand\n  withborder\n  expandiconposition=\"left\"\n  fit=\"small\"\n  change={yourEventHandler(e)}>\n</McAccordion>"
      },
      "Angular": {
        "setup": "npm install @maersk-global/mds-components-core-accordion",
        "import": "import '@maersk-global/mds-components-core-accordion';",
        "minimal": "<mc-accordion\n  (change)=\"yourEventHandler(e)\">\n</mc-accordion>",
        "basic": "<mc-accordion\n  singleexpand\n  withborder\n  expandiconposition=\"left\"\n  fit=\"small\"\n  (change)=\"yourEventHandler(e)\">\n</mc-accordion>"
      },
      "VanillaJs": {
        "setup": "npm install @maersk-global/mds-components-core-accordion",
        "import": "import '@maersk-global/mds-components-core-accordion';",
        "minimal": "<script type=\"module\"\n  src=\"./node_modules/@maersk-global/mds-components-core-accordion/index.js\"></script>\n\n<mc-accordion>\n</mc-accordion>\n\n<script>\n  document.querySelector('mc-accordion').addEventListener('change', (e) => yourEventHandler(e));\n</script>",
        "basic": "<script type=\"module\"\n  src=\"./node_modules/@maersk-global/mds-components-core-accordion/index.js\"></script>\n\n<mc-accordion\n  singleexpand\n  withborder\n  expandiconposition=\"left\"\n  fit=\"small\">\n</mc-accordion>\n\n<script>\n  document.querySelector('mc-accordion').addEventListener('change', (e) => yourEventHandler(e));\n</script>"
      },
      "Lit": {
        "setup": "npm install @maersk-global/mds-components-core-accordion",
        "import": "import '@maersk-global/mds-components-core-accordion';",
        "minimal": "<mc-accordion\n  @change={yourEventHandler(e)}>\n</mc-accordion>",
        "basic": "<mc-accordion\n  singleexpand\n  withborder\n  expandiconposition=\"left\"\n  fit=\"small\"\n  @change={yourEventHandler(e)}>\n</mc-accordion>"
      }
    }
