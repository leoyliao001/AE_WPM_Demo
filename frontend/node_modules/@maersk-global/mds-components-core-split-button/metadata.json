  "usage": {
    "import": "import '@maersk-global/mds-components-core-split-button';",
    "examples": {
      "minimal": "<mc-split-button label=\"Button\"></mc-split-button>",
      "basic": "<mc-split-button label=\"Button\" fit=\"medium\" icon=\"\" appearance=\"primary\" variant=\"filled\"></mc-split-button>",
      "advanced": {
        "CustomisedAppearance": "// JS\nimport \"@maersk-global/mds-components-core-split-button\";\n\n// CSS\nmc-split-button::part(button) {\n  background-color: #40ab35;\n}\n\nmc-split-button::part(split-button-menu) {\n  background-color: #40ab35;\n}\n\nmc-split-button::part(icon) {\n  fill: #ffa500;\n}\nmc-split-button::part(text-and-icon) {\n  gap: 24px;\n}\nmc-split-button::part(split-button-icon) {\n  fill: #ffffff;\n}\n\n// HTML\n <mc-split-button icon=\"heart\">\n   Save Content\n    <mc-list slot=\"menu\">\n       <mc-list-item label=\"Save as draft\"></mc-list-item>\n       <mc-list-item label=\"Save as template\"></mc-list-item>\n       <mc-list-item label=\"Export\"></mc-list-item>\n    </mc-list>\n</mc-split-button>"
      }
    },
    "frameworkExamples": {
      "Vue3": {
        "setup": "npm install @maersk-global/mds-components-core-split-button",
        "import": "import '@maersk-global/mds-components-core-split-button';",
        "minimal": "<mc-split-button\n  label=\"Button\"\n  @click=\"yourEventHandler(e)\"\n  @focus=\"yourEventHandler(e)\"\n  @blur=\"yourEventHandler(e)\">\n</mc-split-button>",
        "basic": "<mc-split-button\n  label=\"Button\"\n  hiddenlabel\n  fit=\"small\"\n  icon=\"airplane\"\n  loading\n  appearance=\"secondary\"\n  variant=\"outlined\"\n  rounded\n  disabled\n  @click=\"yourEventHandler(e)\"\n  @focus=\"yourEventHandler(e)\"\n  @blur=\"yourEventHandler(e)\">\n</mc-split-button>"
      },
