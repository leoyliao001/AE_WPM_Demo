{
  "overview": {
    "packageName": "@maersk-global/mds-components-core-split-button",
    "packageVersion": "2.170.3",
    "description": "Integrates a main action button (`mc-button`) with a dropdown menu (`mc-menu`), allowing users to easily perform the main action and choose from additional options, all within a single, space-saving component.",
    "homepage": "https://designsystem.maersk.com",
    "repository": {
      "type": "git",
      "url": "https://github.com/Maersk-Global/mds.git"
    },
    "tagName": "mc-split-button",
    "customElement": true,
    "category": "Actions, Navigation",
    "purpose": "Integrates a main action button (`mc-button`) with a dropdown menu (`mc-menu`), allowing users to easily perform the main action and choose from additional options, all within a single, space-saving component.",
    "whenToUse": [
      "Use when you want to present a main action (e.g.",
      "\"Save\"",
      "\"Download\") and offer additional options via a dropdown",
      "reducing clutter and grouping related actions together."
    ],
    "whenNotToUse": [
      "Avoid when only one action is needed",
      "or when all actions should be equally visible and accessible as separate buttons."
    ],
    "worksWithComponents": [
      "mc-list",
      "mc-list-item"
    ],
    "alternativeComponentNames": [
      "Dropdown Button",
      "Action Menu Button"
    ],
    "extraNotes": "",
    "summary": {
      "publicProperties": 9,
      "publicMethods": 0,
      "events": 3,
      "slots": 3,
      "cssParts": 5,
      "hasAttributes": false,
      "hasReflectedProperties": false,
