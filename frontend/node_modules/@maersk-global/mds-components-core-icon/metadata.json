        "basic": "<script type=\"module\"\n  src=\"./node_modules/@maersk-global/mds-components-core-icon/index.js\"></script>\n\n<mc-icon\n  size=\"16\"\n  color=\"value\"\n  title=\"value\">\n</mc-icon>"
      },
      "Lit": {
