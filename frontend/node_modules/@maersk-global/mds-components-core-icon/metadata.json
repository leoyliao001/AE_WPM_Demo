  "usage": {
    "import": "import '@maersk-global/mds-components-core-icon';",
    "examples": {
      "minimal": "<mc-icon></mc-icon>",
      "basic": "<mc-icon icon=\"heart\" size=\"20\" color=\"\" iconsDynamicImportPath=\"\" title=\"\"></mc-icon>",
      "advanced": {
        "CustomisedAppearance": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-icon';\n\n// CSS\n.wrapper {\n  display: flex; \n  gap: 1em;\n}\n.box {\n  display: flex; \n  flex-direction: column; \n  align-items: center; \n  gap: 0.5em;\n}\n.part mc-icon::part(icon) {\n  fill: green;\n}\n\n// HTML\n<div class=\"wrapper\">\n  <div class=\"box\">\n    <span>Custom color by using a color property</span>\n    <mc-icon color=\"#42b0d5\" icon=\"heart-solid\"></mc-icon>\n  </div>\n  <div class=\"box part\">\n    <span>Custom color by using a CSS part</span>\n    <mc-icon icon=\"heart-solid\"></mc-icon>\n  </div>\n</div>",
        "SolidIcon": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-icon';\n\n// CSS\n.wrapper {\n  display: flex; \n  gap: 1em;\n}\n.box {\n  display: flex; \n  flex-direction: column; \n  align-items: center; \n  gap: 0.5em;\n}\n\n// HTML\n<div class=\"wrapper\">\n  <div class=\"box\">\n    <span>not liked</span>\n    <mc-icon color=\"#ff0000\" icon=\"heart\"></mc-icon>\n  </div>\n  <div class=\"box\">\n    <span>liked</span>\n    <mc-icon color=\"#ff0000\" icon=\"heart-solid\"></mc-icon>\n  </div>\n</div>",
        "Sizes": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-icon';\n\n// CSS\n.wrapper {\n  display: flex; \n  gap: 1em;\n}\n.box {\n  display: flex; \n  flex-direction: column; \n  align-items: center; \n  gap: 0.5em;\n}\n.size48::part(icon) {\n  transform: scale(2);\n}\n\n// HTML\n<div class=\"wrapper\">\n  <div class=\"box\">\n    <span>small - 16px</span>\n    <mc-icon size=\"16\" icon=\"heart\"></mc-icon>\n  </div>\n  <div class=\"box\">\n    <span>small - 20px</span>\n    <mc-icon icon=\"heart\"></mc-icon>\n  </div>\n  <div class=\"box\">\n    <span>large - 24px</span>\n    <mc-icon size=\"24\" icon=\"heart\"></mc-icon>\n  </div>\n  <div class=\"box\">\n    <span>custom width of 48px</span>\n    <mc-icon size=\"24\" icon=\"heart\"></mc-icon>\n  </div>\n</div>",
        "DynamicImportPath": "// JavaScript\nimport { MdsConfig } from '@maersk-global/mds-config';\nMdsConfig.iconsDynamicImportPath = '/node_modules/';\nif (import.meta.env.PROD) {\n  MdsConfig.iconsDynamicImportPath = './';\n}\n",
        "CustomTitle": "<div class=\"wrapper\">\n      <div class=\"box\">\n        <span>The title on this icon reads \"My empty heart\"</span>\n        <mc-icon color=\"red\" icon=\"heart\" title=\"My empty heart\"></mc-icon>\n      </div>\n      <div class=\"box part\">\n        <span>The title for this icon reads \"My heart is full\"</span>\n        <mc-icon color=\"red\" icon=\"heart-solid\" title=\"My heart is full\"></mc-icon>\n      </div>\n      <p>\n        If no title is provided, the name of the icon is used. Without that, a screen reader announces the icon as\n        \"image\"\n      </p>\n    </div>\n"
      }
    },
