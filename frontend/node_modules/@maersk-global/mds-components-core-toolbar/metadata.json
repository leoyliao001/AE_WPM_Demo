  "usage": {
    "import": "import '@maersk-global/mds-components-core-toolbar';",
    "examples": {
      "minimal": "<mc-toolbar></mc-toolbar>",
      "basic": "<mc-toolbar wrapbreakpoint=\"x-small\"></mc-toolbar>",
      "advanced": {
        "TableWithBulkActions": "// JS\nimport \"@maersk-global/mds-components-core-toolbar\";\nimport \"@maersk-global/mds-components-core-button-group\";\nimport \"@maersk-global/mds-components-core-button-group-item\";\n\n// HTML\n<mc-toolbar>\n  <div slot=\"end\">\n    <b>1 item(s) selected</b>\n    <mc-button-group hiddenlegend>\n      <mc-button-group-item value=\"Add\" icon=\"plus\">Add</mc-button-group-item>\n      <mc-button-group-item value=\"Duplicate\" icon=\"file-copy\">Duplicate</mc-button-group-item>\n      <mc-button-group-item value=\"Delete\" icon=\"trash\">Delete</mc-button-group-item>\n    </mc-button-group>\n  </div>\n</mc-toolbar>",
        "TableWithPagination": "// JS\nimport \"@maersk-global/mds-components-core-toolbar\";\nimport \"@maersk-global/mds-components-core-select\";\nimport \"@maersk-global/mds-components-core-option\";\nimport \"@maersk-global/mds-components-core-pagination\";\n\n// HTML\n<mc-toolbar>\n  <div slot=\"end\">\n    <mc-select labelposition=\"left\" style=\"width: 140px;\" label=\"Show\" value=\"10\">\n      <mc-option value=\"10\">10</mc-option>\n      <mc-option value=\"25\">25</mc-option>\n      <mc-option value=\"50\">50</mc-option>\n      <mc-option value=\"100\">100</mc-option>\n    </mc-select>\n    <mc-pagination totalpages=\"3\" currentpage=\"1\" visiblepages=\"3\"></mc-pagination>\n  </div>\n</mc-toolbar>",
        "WithDivider": "// JS\nimport \"@maersk-global/mds-components-core-toolbar\";\nimport \"@maersk-global/mds-components-core-button\";\nimport \"@maersk-global/mds-components-core-button-group\";\nimport \"@maersk-global/mds-components-core-button-group-item\";\nconst toolbar = document.querySelectorAll('mc-button-group');\ntoolbar[0].value = 'align-justify';\ntoolbar[1].value = 'chart-bars';\n\n// HTML\n<mc-toolbar wrapbreakpoint=\"small\">\n  <div slot=\"start\">\n    <mc-button-group variant=\"borderless\" selectiontype=\"single\">\n      <mc-button-group-item\n        appearance=\"neutral\"\n        variant=\"plain\"\n        icon=\"bars-horizontal\"\n        label=\"Align Justify\"\n        value=\"align-justify\"\n        hiddenlabel\n      ></mc-button-group-item>\n      <mc-button-group-item\n        appearance=\"neutral\"\n        variant=\"plain\"\n        icon=\"bars-horizontal-funnel-left\"\n        label=\"Align Left\"\n        value=\"align-left\"\n        hiddenlabel\n      ></mc-button-group-item>\n      <mc-button-group-item\n        appearance=\"neutral\"\n        variant=\"plain\"\n        icon=\"bars-horizontal-funnel-down\"\n        label=\"Align Center\"\n        value=\"align-center\"\n        hiddenlabel\n      ></mc-button-group-item>\n    </mc-button-group>\n    <hr class=\"vertical\" />\n    <mc-button\n      appearance=\"neutral\"\n      variant=\"plain\"\n      icon=\"bars-horizontal-bullets\"\n      label=\"list\"\n      hiddenlabel\n    ></mc-button>\n    <hr class=\"vertical\" />\n    <mc-button-group variant=\"borderless\" selectiontype=\"single\">\n      <mc-button-group-item\n        appearance=\"neutral\"\n        variant=\"plain\"\n        icon=\"chart-line-up\"\n        label=\"Chart Line\"\n        value=\"chart-line\"\n        hiddenlabel\n      ></mc-button-group-item>\n      <mc-button-group-item\n        appearance=\"neutral\"\n        variant=\"plain\"\n        icon=\"chart-bars-vertical\"\n        label=\"Chart Bars\"\n        value=\"chart-bars\"\n        hiddenlabel\n      ></mc-button-group-item>\n      <mc-button-group-item\n        appearance=\"neutral\"\n        variant=\"plain\"\n        icon=\"chart-pie\"\n        label=\"Chart Pie\"\n        value=\"chart-pie\"\n        hiddenlabel\n      ></mc-button-group-item>\n    </mc-button-group>\n    <hr class=\"vertical\" />\n    <span>Edited 2 hours ago</span>\n  </div>\n  <div slot=\"end\">\n    <mc-button label=\"Share\"></mc-button>\n  </div>\n</mc-toolbar>"
      }
    },
