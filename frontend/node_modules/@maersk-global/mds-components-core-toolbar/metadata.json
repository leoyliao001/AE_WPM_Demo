  "api": {
    "props": [
      {
        "name": "wrapbreakpoint",
        "type": "Viewport",
        "defaultValue": "x-small",
        "description": "Specifies the wrap breakpoint for the toolbar, after which the toolbar slots (start, center and end) will stack vertically. \n\rThe default value is \"x-small\", which means that the toolbar will stack on viewports smaller than 640px. \n\rIf you select \"small\", the toolbar will stack on viewports smaller than 1024px.",
        "options": [
          "x-small",
          "small"
        ],
        "required": false,
        "category": "Style"
      }
    ],
    "events": [],
    "slots": [
      {
        "description": "Use the start named slot, when you want to place components at the beginning of the toolbar.. Check stories under <b>Examples</b> folder to see live example.",
        "name": "start",
        "isDefault": false,
        "isNamed": true,
        "example": "<mc-toolbar>\n  <span slot=\"start\">\n    <mc-button>Save</mc-button><mc-button appearance=\"neutral\">Cancel</mc-button>\n  </span>\n</mc-toolbar>"
      },
      {
        "description": "Use the center named slot, when you want to place components at the middle of the toolbar.. Check stories under <b>Examples</b> folder to see live example.",
        "name": "center",
        "isDefault": false,
        "isNamed": true,
        "example": "<mc-toolbar>\n  <span slot=\"center\">\n    <mc-input label=\"Search\" icon=\"magnifying-glass\" placeholder=\"Type to search...\" hiddenlabel></mc-input>\n  </span>\n</mc-toolbar>"
      },
      {
        "description": "Use the end named slot, when you want to place components at the end of the toolbar.. Check stories under <b>Examples</b> folder to see live example.",
        "name": "end",
        "isDefault": false,
        "isNamed": true,
        "example": "<mc-toolbar>\n  <span slot=\"end\">\n    <mc-button appearance=\"neutral\" variant=\"plain\" label=\"Settings\" hiddenlabel icon=\"cog\"></mc-button><mc-avatar info=\"User Avatar\" initials=\"JD\" appearance=\"color-2\"></mc-avatar>\n  </span>\n</mc-toolbar>"
      }
    ],
