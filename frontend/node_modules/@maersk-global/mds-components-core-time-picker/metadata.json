  "usage": {
    "import": "import '@maersk-global/mds-components-core-time-picker';",
    "examples": {
      "minimal": "<mc-time-picker></mc-time-picker>",
      "basic": "<mc-time-picker hourstep=\"1\" minutestep=\"1\" fit=\"medium\" value=\"\"></mc-time-picker>",
      "advanced": {
        "WithMinuteAndHourIntervals": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-time-picker\";\n\n// HTML\n<mc-time-picker hourstep=\"2\" minutestep=\"10\"></mc-time-picker>\n",
        "CustomisedAppearance": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-time-picker\";\n// CSS\nmc-time-picker::part(hours-container) {\n  background-color: #40AB35;\n}\nmc-time-picker::part(minutes-container) {\n  background-color: #40AB35;\n}\n// HTML\n<mc-time-picker></mc-time-picker>\n  "
      }
    },
    "frameworkExamples": {
      "Vue3": {
        "setup": "npm install @maersk-global/mds-components-core-time-picker",
        "import": "import '@maersk-global/mds-components-core-time-picker';",
        "minimal": "<mc-time-picker\n  @timeselected=\"yourEventHandler(e)\">\n</mc-time-picker>",
        "basic": "<mc-time-picker\n  preselectcurrenttime\n  fit=\"small\"\n  value=\"value\"\n  @timeselected=\"yourEventHandler(e)\">\n</mc-time-picker>"
      },
