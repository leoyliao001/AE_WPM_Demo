      {
        "name": "IMcTimePicker",
        "kind": "interface",
        "members": [
          {
            "name": "fit",
            "type": "Fit",
            "optional": true,
            "description": "Fit of the input."
          },
          {
            "name": "hourstep",
            "type": "number",
            "optional": true,
            "description": "A numeric value that indicates the level of granularity that the hour items must meet.\nIt can range between greater than 1 and less than 23. For more details, see the examples."
          },
          {
            "name": "minutestep",
            "type": "number",
            "optional": true,
            "description": "A numeric value that indicates the level of granularity that the minute items must meet.\nIt can range between greater than 1 and less than 59. For more details, see the examples."
          },
          {
            "name": "preselectcurrenttime",
            "type": "boolean",
            "optional": true,
            "description": "True, if the current local time must be preselected."
