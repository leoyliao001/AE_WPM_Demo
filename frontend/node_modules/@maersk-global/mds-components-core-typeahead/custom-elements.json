        {
          "kind": "class",
          "description": "Purpose: A typeahead (autocomplete) component that provides real-time suggestions as users type into an input field.\nCategory: Forms, Actions\nWhen to use: When you need to provide users with suggestions based on their input.\nWhen not to use: When you have a fixed set of options that do not change based on user input.\nWorks with components: mc-option, mc-accordion-item, mc-card, mc-dialog, mc-drawer, mc-modal, mc-popover, mc-step-indicator-item, mc-table, mc-tabs\nAlternative component names: Autocomplete, Search Suggestions, Predictive Search, Smart Search, Dropdown Search, Filtered Select",
          "name": "McTypeahead",
          "cssParts": [
            {
              "description": "for changing visuals of label container",
              "name": "`label-container`"
            },
            {
