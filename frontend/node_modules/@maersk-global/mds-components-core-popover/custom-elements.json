            {
              "kind": "field",
              "name": "detectOverflowMiddleware",
              "type": {
                "text": "Middleware"
              },
              "privacy": "private",
              "default": "{ name: 'detectOverflowMiddleware', fn: async (state) => { const { top, bottom } = await detectOverflow(state, { padding: 8 }); if (top > 0) { this.latestOverflow = top; const newHeight = state.rects.floating.height - top; if (this.container) { this.container.style.maxHeight = `${newHeight}px`; } return {}; } if (bottom > 0) { this.latestOverflow = bottom; const newHeight = state.rects.floating.height - bottom; if (this.container) { this.container.style.maxHeight = `${newHeight}px`; } return {}; } if (this.latestOverflow > 0 && top < 0 && bottom < 0 && this.container) { this.container.style.maxHeight = 'none'; } return {}; }, }"
