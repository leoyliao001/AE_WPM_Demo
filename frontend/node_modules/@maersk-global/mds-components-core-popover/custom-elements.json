        {
          "kind": "class",
          "description": "Purpose: Popover displays floating content next to a trigger element.\nCategory: Content Display, Forms\nWhen to use: When you need to display additional information related to a specific element.\nWhen not to use: When you have a small amount of information to display.\nWorks with components: mc-button, mc-tooltip\nAlternative component names: Tooltip, Context Menu, Dropdown, Info Box",
          "name": "McPopover",
          "cssParts": [
            {
              "description": "for changing visuals of popover container",
              "name": "`container`"
            },
            {
              "description": "for changing visuals of popover content",
              "name": "`content`"
            },
            {
              "description": "for changing visuals of arrow",
              "name": "`arrow`"
            }
          ],
          "slots": [
            {
              "description": "The default slot where the content of the popover displays",
              "name": ""
            },
            {
              "description": "slot where the element that will trigger popover goes. Not used when customtriggerelement property is set.",
              "name": "`trigger`"
            },
            {
              "description": "sets the modal heading when the popover is set to be shown as a modal for specific screen sizes, using the \"modalmode\" prop.",
              "name": "`heading`"
            },
            {
              "description": "sets the modal footer when the popover is set to be shown as a modal for specific screen sizes, using the \"modalmode\" prop.",
              "name": "`footer`"
            }
          ],
