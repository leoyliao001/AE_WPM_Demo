    "events": [
      {
        "name": "disabledchange",
        "description": "Fired when disabled status of a tab changes.",
        "type": "CustomEvent"
      }
    ],
    "slots": [
      {
        "description": "Use the default slot, when you want to pass the label as HTML. Check stories under <b>Examples</b> folder to see live example.",
        "name": "",
        "isDefault": true,
        "isNamed": false,
        "example": "<mc-tab>\n  Label as HTML\n</mc-tab>"
      },
      {
        "description": "Use the prefix named slot, to specify the prefix graphic such as an icon, image or pictogram.. Check stories under <b>Examples</b> folder to see live example.",
        "name": "prefix",
        "isDefault": false,
        "isNamed": true,
        "example": "<mc-tab>\n  <span slot=\"prefix\">\n    <mc-icon slot=\"prefix\" icon=\"heart\"></mc-icon>\n  </span>\n</mc-tab>"
      },
      {
        "description": "Use the suffix named slot, to specify the suffix graphic such as an icon, image or pictogram.. Check stories under <b>Examples</b> folder to see live example.",
        "name": "suffix",
        "isDefault": false,
        "isNamed": true,
        "example": "<mc-tab>\n  <span slot=\"suffix\">\n    <mc-icon slot=\"suffix\" icon=\"heart\"></mc-icon>\n  </span>\n</mc-tab>"
      },
      {
        "description": "Use the badge slot, when you want to attach badge to the list item. Check stories under badge <b>Examples</b> folder to see live example.",
        "name": "badge",
        "isDefault": false,
        "isNamed": true,
        "example": "<mc-list-item>\n  <mc-badge \n    slot=\"badge\" \n    label=\"99\" \n    variant=\"error\">\n  </mc-badge>\n</mc-list-item>"
      }
    ],
    "types": [
      {
        "name": "Fit",
        "kind": "re-export"
      },
      {
        "name": "IMcTab",
        "kind": "interface",
        "members": [
          {
            "name": "disabled",
            "type": "boolean",
            "optional": true,
            "description": "Sets tab button in the `disabled` state, which will disable any user interaction with the tab button."
          },
          {
            "name": "id",
            "type": "string",
            "optional": true,
            "description": "Id of the tab.\n@default 'tab'"
          },
          {
            "name": "label",
            "type": "string",
            "optional": true,
            "description": "Label has to be passed as a property.\nIt is required attribute as it will be used as `aria-label`."
          },
          {
            "name": "icon",
            "type": "string",
            "optional": true,
            "description": "Name of the icon."
          },
          {
            "name": "trailingicon",
            "type": "string",
            "optional": true,
            "description": "Name of the railing icon."
          },
          {
            "name": "fit",
            "type": "Fit",
            "optional": true,
            "description": "Fit of the tab.\n@default 'medium'"
          },
          {
            "name": "active",
            "type": "boolean",
            "optional": true,
            "description": "Sets tab to `active` state.\n@default false"
          },
          {
            "name": "tabindex",
            "type": "number",
            "optional": true,
            "description": "Sets `tabindex` of the tab."
          },
          {
            "name": "index",
            "type": "number",
            "optional": true,
            "description": "Gets the index of the tab when sitting in a tab-bar.\nUsed to orchestrate the focus keyboard navigation."
          },
          {
            "name": "slot",
            "type": "string",
            "optional": true,
            "description": "Slot name of the tab."
          }
        ]
      }
    ]
  },
