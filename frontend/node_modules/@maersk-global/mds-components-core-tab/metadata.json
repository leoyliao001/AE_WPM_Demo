{
  "overview": {
    "packageName": "@maersk-global/mds-components-core-tab",
    "packageVersion": "2.170.3",
    "description": "A tabbed interface that allows users to navigate between different views or sections of content within the same page.",
    "homepage": "https://designsystem.maersk.com",
    "repository": {
      "type": "git",
      "url": "https://github.com/Maersk-Global/mds.git"
    },
    "tagName": "mc-tab",
    "customElement": true,
    "category": "Content Display, Navigation, Layout",
    "purpose": "A tabbed interface that allows users to navigate between different views or sections of content within the same page.",
    "whenToUse": [
      "When you need to display multiple views or sections of content in a compact space."
    ],
    "whenNotToUse": [
      "For single-view interfaces or when a simple dropdown menu suffices."
    ],
    "worksWithComponents": [
      "mc-tab-bar"
    ],
    "alternativeComponentNames": [
      "Tabbed Navigation",
      "Tabbed Interface",
      "Tab Control",
      "Tab Panel",
      "Tab View"
    ],
    "extraNotes": "",
    "summary": {
      "publicProperties": 9,
      "publicMethods": 2,
      "events": 1,
      "slots": 4,
      "cssParts": 3,
      "hasAttributes": true,
      "hasReflectedProperties": true,
      "hasDeprecatedProperties": false,
      "hasSlots": true,
      "hasEvents": true,
      "hasCssParts": true
    }
  },
  "usage": {
    "import": "import '@maersk-global/mds-components-core-tab';",
    "examples": {
      "minimal": "<mc-tab label=\"Tab text\"></mc-tab>",
      "basic": "<mc-tab label=\"Tab text\" prefix=\"\" suffix=\"\" fit=\"medium\" icon=\"\" trailingicon=\"\" width=\"auto\"></mc-tab>",
      "advanced": {
        "WithTag": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-tab';\n\n// HTML\n<mc-tab label=\"Overdue\">\n  <span slot=\"suffix\"><mc-tag appearance=\"error\" fit=\"small\" label=\"3\"></mc-tag></span>\n</mc-tab>\n",
        "PrefixAndSuffix": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-tab';\n    \n// CSS\n.prefix:before {\n  content: '\\\\2713';\n  display: inline-block;\n  color: green;\n  padding: 0 6px 0 0;\n}\n\n// HTML\n<mc-tab label=\"Prices\">\n  <span class=\"prefix\" slot=\"prefix\">prefix</span>\n  <span slot=\"suffix\">$</span>\n</mc-tab>\n",
        "CustomisedAppearance": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-tab\";\n\n// CSS\nmc-tab::part(button) {\n  color: #40AB35;\n}\nmc-tab::part(text-and-icon) {\n  flex-direction: column;\n}\nmc-tab::part(icon) {\n  fill: #40AB35;\n}\n\n// HTML\n<mc-tab icon=\"apple\">\n    Apple\n</mc-tab>\n  "
      }
    },
    "frameworkExamples": {
      "Vue3": {
        "setup": "npm install @maersk-global/mds-components-core-tab",
        "import": "import '@maersk-global/mds-components-core-tab';",
        "minimal": "<mc-tab\n  @disabledchange=\"yourEventHandler(e)\">\n</mc-tab>",
        "basic": "<mc-tab\n  prefix=\"value\"\n  suffix=\"value\"\n  fit=\"small\"\n  icon=\"airplane\"\n  trailingicon=\"airplane\"\n  disabled\n  active\n  width=\"full-width\"\n  @disabledchange=\"yourEventHandler(e)\">\n</mc-tab>"
      },
      "Vue2": {
        "setup": "npm install @maersk-global/mds-components-core-tab",
        "import": "import '@maersk-global/mds-components-core-tab';",
        "minimal": "<mc-tab\n  @disabledchange=\"yourEventHandler(e)\">\n</mc-tab>",
        "basic": "<mc-tab\n  prefix=\"value\"\n  suffix=\"value\"\n  fit=\"small\"\n  icon=\"airplane\"\n  trailingicon=\"airplane\"\n  disabled\n  active\n  width=\"full-width\"\n  @disabledchange=\"yourEventHandler(e)\">\n</mc-tab>"
      },
      "React": {
        "setup": "npm install @maersk-global/mds-components-core-tab",
        "import": "import { McTab } from \"@maersk-global/mds-react-wrapper/components-core/mc-tab\";",
        "minimal": "<McTab\n  disabledchange={yourEventHandler(e)}>\n</McTab>",
        "basic": "<McTab\n  prefix=\"value\"\n  suffix=\"value\"\n  fit=\"small\"\n  icon=\"airplane\"\n  trailingicon=\"airplane\"\n  disabled\n  active\n  width=\"full-width\"\n  disabledchange={yourEventHandler(e)}>\n</McTab>"
      },
      "Angular": {
        "setup": "npm install @maersk-global/mds-components-core-tab",
        "import": "import '@maersk-global/mds-components-core-tab';",
        "minimal": "<mc-tab\n  (disabledchange)=\"yourEventHandler(e)\">\n</mc-tab>",
        "basic": "<mc-tab\n  prefix=\"value\"\n  suffix=\"value\"\n  fit=\"small\"\n  icon=\"airplane\"\n  trailingicon=\"airplane\"\n  disabled\n  active\n  width=\"full-width\"\n  (disabledchange)=\"yourEventHandler(e)\">\n</mc-tab>"
      },
      "VanillaJs": {
        "setup": "npm install @maersk-global/mds-components-core-tab",
        "import": "import '@maersk-global/mds-components-core-tab';",
        "minimal": "<script type=\"module\"\n  src=\"./node_modules/@maersk-global/mds-components-core-tab/index.js\"></script>\n\n<mc-tab>\n</mc-tab>\n\n<script>\n  document.querySelector('mc-tab').addEventListener('disabledchange', (e) => yourEventHandler(e));\n</script>",
        "basic": "<script type=\"module\"\n  src=\"./node_modules/@maersk-global/mds-components-core-tab/index.js\"></script>\n\n<mc-tab\n  prefix=\"value\"\n  suffix=\"value\"\n  fit=\"small\"\n  icon=\"airplane\"\n  trailingicon=\"airplane\"\n  disabled\n  active\n  width=\"full-width\">\n</mc-tab>\n\n<script>\n  document.querySelector('mc-tab').addEventListener('disabledchange', (e) => yourEventHandler(e));\n</script>"
      },
      "Lit": {
        "setup": "npm install @maersk-global/mds-components-core-tab",
        "import": "import '@maersk-global/mds-components-core-tab';",
        "minimal": "<mc-tab\n  @disabledchange={yourEventHandler(e)}>\n</mc-tab>",
        "basic": "<mc-tab\n  prefix=\"value\"\n  suffix=\"value\"\n  fit=\"small\"\n  icon=\"airplane\"\n  trailingicon=\"airplane\"\n  disabled\n  active\n  width=\"full-width\"\n  @disabledchange={yourEventHandler(e)}>\n</mc-tab>"
      }
    }
