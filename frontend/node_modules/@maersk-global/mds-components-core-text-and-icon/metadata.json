  "usage": {
    "import": "import '@maersk-global/mds-components-core-text-and-icon';",
    "examples": {
      "minimal": "<mc-text-and-icon label=\"Label\"></mc-text-and-icon>",
      "basic": "<mc-text-and-icon label=\"Label\" sublabel=\"\" fit=\"medium\" icon=\"\" trailingicon=\"\"></mc-text-and-icon>",
      "advanced": {
        "LabelAndIconsAsSlot": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-text-and-icon';\n\n// HTML\n<mc-text-and-icon>\n  <span slot=\"icon\"><mc-icon icon=\"heart\"></mc-icon></span>\n  Text\n  <span slot=\"sublabel\">Sub-label as HTML</span>\n  <span slot=\"trailingicon\"><mc-icon icon=\"info-circle\"></mc-icon></span>\n</mc-text-and-icon>",
        "CustomLeadingIcon": "// JavaScript\nimport '@maersk-global/mds-components-core/mc-text-and-icon';\n\n// HTML\n<mc-text-and-icon>\n  <span slot=\"icon\"><img src=\"src-to-your-image\" width=\"20\" height=\"20\"></span>\n  GitHub\n</mc-text-and-icon>",
        "CustomisedAppearance": "// JavaScript\nimport \"@maersk-global/mds-components-core/mc-text-and-icon\";\n\n// CSS\nmc-text-and-icon::part(text-and-icon) {\n  gap: 24px;\n}\nmc-text-and-icon::part(icon) {\n  fill: #767676;\n}\nmc-text-and-icon::part(text-and-icon-label) {\n  width: 100%;\n}\nmc-text-and-icon::part(text-and-icon-label):after {\n  content: ' ...';\n}\n\n// HTML\n<mc-text-and-icon\n  icon=\"apple\"\n  trailingicon=\"banana\"\n>\n  <b>Fruits</b>\n  <span slot=\"sublabel\" class=\"mds-neutral--weak__text-color\">Most common ones</span>\n</mc-text-and-icon>\n  "
      }
    },
