{
  "overview": {
    "packageName": "@maersk-global/mds-components-core-segmented-control-item",
    "packageVersion": "2.170.3",
    "description": "A segmented control item to be used within an `mc-segmented-control`.",
    "homepage": "https://designsystem.maersk.com",
    "repository": {
      "type": "git",
      "url": "https://github.com/Maersk-Global/mds.git"
    },
    "tagName": "mc-segmented-control-item",
    "customElement": true,
    "category": "Navigation, Content Display, Data Display",
    "purpose": "A segmented control item to be used within an `mc-segmented-control`.",
    "whenToUse": [
      "When you need to present multiple related options in a compact space."
    ],
    "whenNotToUse": [
      "For unrelated options or when space is not a concern."
    ],
    "worksWithComponents": [
      "mc-segmented-control"
    ],
    "alternativeComponentNames": [
      "Segmented Button Group",
      "Tabbed Navigation"
    ],
